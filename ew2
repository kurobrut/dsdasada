-- FUNCTIONS
-------------------------------------------------

local function sendMarshmallowBatch()

	local args = {
		{
			interior_name = "MainMap!Sugarfest2026",
			marshmallow_ids = marshmallowIds
		}
	}

	pcall(function()
		marshmallowEvent:FireServer(unpack(args))
	end)

end

local function collectMarshmallows()

	pcall(function()
		collectEvent:FireServer()
	end)

end

-------------------------------------------------
-- LOOP SYSTEM
-------------------------------------------------

local running = false

local function farmLoop()

	while running do

		sendMarshmallowBatch()

		task.wait(0.5)

		collectMarshmallows()

		task.wait(1)

	end

end

-------------------------------------------------
-- KEYBIND (PRESS F)
-------------------------------------------------

UserInputService.InputBegan:Connect(function(input, gameProcessed)

	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.F then

		running = not running

		if running then
			print("Marshmallow Farm: ON")
			task.spawn(farmLoop)
		else
			print("Marshmallow Farm: OFF")
		end

	end

end)
