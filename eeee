-- ==================== MAIN FARM ====================
local PetFarmFunction = function()
	SetPlatformForPlayer(true)
	if not AutoFarmFunctions.PetAutofarm.State then
		SetPlatformForPlayer(false)
		AutoFarmFunctions.PetAutofarm.Running = false
		return
	end

	if SelectedPet ~= "None" then
		local ailments = AdoptMeConfigs.GetAilments(SelectedPet, nil, false, {})
		if ailments and ailments.FirstPet then
			for needType in pairs(ailments.FirstPet) do
				if DoPetNeed[needType] then
					pcall(function()
						DoPetNeed[needType](SelectedPet)
					end)
				end
			end
		end
	end

	if DoBabyAutoFarm then
		local ailments = AdoptMeConfigs.GetAilments(nil, nil, true, {})
		if ailments and ailments.Baby then
			for needType in pairs(ailments.Baby) do
				if DoBabyNeed[needType] then
					pcall(DoBabyNeed[needType])
				end
			end
		end
	end

	AutoFarmFunctions.PetAutofarm.Running = false
	task.wait(2)
end

-- ==================== LOOP ====================
task.spawn(function()
    BucksStart = ClientData.get("money") or 0
    AgePotionsStart = GetAgePotionsCount()
    BucksLast = BucksStart
    AgePotionsLast = AgePotionsStart
    BucksLastUpdate = tick()
    AgePotionsLastUpdate = tick()
    
    while true do
        task.wait(1)
        local currentBucks = ClientData.get("money") or 0
        local bucksSession = currentBucks - BucksStart
        BucksLabel:Set(string.format("Bucks: %s (+%s this session) | Rate: %s/min", currentBucks, bucksSession, BucksRate))
       
        local currentPotions = GetAgePotionsCount()
        local now = tick()
        local pGained = currentPotions - AgePotionsLast
        local pTime = now - AgePotionsLastUpdate
        if pTime > 0 and pGained > 0 then
            AgePotionsRate = math.floor((pGained / pTime) * 60 + 0.5)
        elseif pTime > 60 then
            AgePotionsRate = 0
        end
        AgePotionsLast = currentPotions
        AgePotionsLastUpdate = now
       
        local potionsSession = currentPotions - AgePotionsStart
        PotionsLabel:Set(string.format("Age Potions: %s (+%s this session) | Rate: %s/min", currentPotions, potionsSession, AgePotionsRate))
    end
end)

