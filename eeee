-- ==================== MAIN FARM ====================
local PetFarmFunction = function()
    SetPlatformForPlayer(true)
    if not AutoFarmFunctions.PetAutofarm.State then
        SetPlatformForPlayer(false)
        AutoFarmFunctions.PetAutofarm.Running = false
        return
    end

    if SelectedPet ~= "None" then
        local ailments = AdoptMeConfigs.GetAilments(SelectedPet, nil, false, {})
        if ailments and ailments.FirstPet then
            for needType in pairs(ailments.FirstPet) do
                if DoPetNeed[needType] then
                    pcall(function()
                        DoPetNeed[needType](SelectedPet)
                    end)
                end
            end
        end
    end

    if DoBabyAutoFarm then
        local ailments = AdoptMeConfigs.GetAilments(nil, nil, true, {})
        if ailments and ailments.Baby then
            for needType in pairs(ailments.Baby) do
                if DoBabyNeed[needType] then
                    pcall(DoBabyNeed[needType])
                end
            end
        end
    end

    AutoFarmFunctions.PetAutofarm.Running = false
    task.wait(2)
end

