ClientData.register_callback("money", function(player, newValue, oldValue)
    if player ~= LocalPlayer then return end
    local now = tick()
    local gained = (newValue or 0) - (oldValue or BucksLast)
    local timeDiff = now - BucksLastUpdate
    if timeDiff > 0 and gained > 0 then
        BucksRate = math.floor((gained / timeDiff) * 60 + 0.5)
    elseif timeDiff > 60 then
        BucksRate = 0
    end
    BucksLast = newValue or 0
    BucksLastUpdate = now
end)

local function GetAgePotionsCount()
    local inv = AdoptMeConfigs.GetPlayersInventory()
    local count = 0
    for _, category in pairs({"food", "items", "potions", "consumables", "inventory"}) do
        local section = inv[category]
        if section and typeof(section) == "table" then
            for _, data in pairs(section) do
                if data and data.id and data.id:lower():find("age") and data.id:lower():find("potion") then
                    count = count + (data.amount or (data.properties and data.properties.amount) or 1)
                end
            end
        end
    end
    return count
end

