function UpdatePlayerPets()
    AdoptMeConfigs.UnequipAllPets()
    if SelectedPet ~= "None" then
        AdoptMeConfigs.EquipPet(SelectedPet, false)
    end
end

local PetDropdown = AutofarmTab:CreateDropdown({
    Name = "Select Pet",
    Options = PlayerPetsTabel,
    CurrentOption = { "None" },
    MultipleOptions = false,
    Callback = function(Option)
        local selected = Option[1]
        if selected == "None" then
            SelectedPet = "None"
            return
        end
        local idx = tonumber(AdoptMeConfigs.GetNumberBeforeEqual(selected))
        if not PlayersPets[idx] or not PlayersPets[idx].id then return end
        local PetId = PlayersPets[idx].id
        if not string.find(selected, PlayersPets[idx].kind) or
           not string.find(selected, AdoptMeConfigs.GetFirstSixLetters(PetId)) then
            SelectedPet = "None"
            PetDropdown:Set({ "None" })
            Notification("Pet changed or removed")
            return
        end
        SelectedPet = PetId
        UpdatePlayerPets()
    end
})

AutofarmTab:CreateButton({Name = "Refresh Pets", Callback = UpdatePetDropdown})

AutofarmTab:CreateToggle({
