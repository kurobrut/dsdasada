-- ==================== PLATFORM + MOVEMENT ====================
function updatePlatformForLocalPlayer()
	if not LocalPlayer or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
	local rootPart = LocalPlayer.Character.HumanoidRootPart
	if workspace:FindFirstChild("PlayerPlatform") then platform = workspace:FindFirstChild("PlayerPlatform") end
	if not platform then
		platform = Instance.new("Part")
		platform.Size = platformSize
		platform.Color = platformColor
		platform.Anchored = true
		platform.CanCollide = true
		platform.Name = "PlayerPlatform"
		platform.Parent = workspace
	end
	if math.abs(platform.Position.Y - (rootPart.Position.Y - (rootPart.Size.Y / 2 + platform.Size.Y / 2) - 2)) > 10 then
		platform.Position = rootPart.Position - Vector3.new(0, (rootPart.Size.Y / 2 + platform.Size.Y / 2) + 2, 0)
	end
	platform.Color = platformColor
end

function SetPlatformForPlayer(state)
	platformActive = state
	if platformActive then
		spawn(function()
			while platformActive do
				updatePlatformForLocalPlayer()
				task.wait(0.5)
			end
		end)
	end
end

function DeleteAllPlatforms()
	for _, v in pairs(workspace:GetChildren()) do
		if v:IsA("Part") and v.Name == "PlayerPlatform" then v:Destroy() end
	end
	platform = nil
end

local function startMoving(state)
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	if state then
		if isRunning then return end
		isRunning = true
		local function getNextCirclePoint(center, angle)
			return center + Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
		end
		local center = character.PrimaryPart.Position
		local jumpTimer = 0
		runService:BindToRenderStep("CircleMovement", Enum.RenderPriority.Character.Value, function(deltaTime)
			if not isRunning then return end
			angle = angle + speed * deltaTime
			humanoid:MoveTo(getNextCirclePoint(center, angle))
			center = character.PrimaryPart.Position
			jumpTimer = jumpTimer + deltaTime
			if jumpTimer >= jumpInterval then humanoid.Jump = true jumpTimer = 0 end
		end)
	else
		isRunning = false
		runService:UnbindFromRenderStep("CircleMovement")
		humanoid:Move(Vector3.new(0,0,0), false)
		humanoid:MoveTo(character.PrimaryPart.Position)
		task.spawn(function() task.wait(0.1) humanoid.Jump = true end)
	end
end

-- ==================== PET HELPERS ====================
function UpdatePlayerPets()
	AdoptMeConfigs.UnequipAllPets()
	if FirstSelectedPet ~= "None" then AdoptMeConfigs.EquipPet(FirstSelectedPet, false) end
	if SecondSelectedPet ~= "None" then AdoptMeConfigs.EquipPet(SecondSelectedPet, true) end
end

function ResetPlayerPets()
	if FirstSelectedPet ~= "None" then FirstSelectedPet = "None" FirstPetDropdown:Set({"None"}) end
	if SecondSelectedPet ~= "None" then SecondSelectedPet = "None" SecondPetDropdown:Set({"None"}) end
end

function UpdatePetDropdownForSearch(TextToSearch)
	local NewPetsTable = {}
	for _, v in pairs(PlayerPetsTabel) do
		if string.find(v:lower(), TextToSearch:lower()) then table.insert(NewPetsTable, v) end
	end
	FirstPetDropdown:Refresh(NewPetsTable)
	SecondPetDropdown:Refresh(NewPetsTable)
end

function UpdatePetDropdown()
	PlayersPets = {}
	PlayerPetsTabel = {}
	local sortablePets = {}
	for petid, petname in pairs(AdoptMeConfigs.GetPlayersInventory().pets) do
		if petname.id ~= "practice_dog" then
			table.insert(sortablePets, {id = petid, name = petname.id, age = petname.properties.age})
		end
	end
	table.sort(sortablePets, function(a,b)
		if a.name:lower() == b.name:lower() then return AdoptMeConfigs.NaturalSort(a.id, b.id) end
		return a.name:lower() < b.name:lower()
	end)
	for index, pet in ipairs(sortablePets) do
		local entry = index .. "=" .. pet.name .. ": " .. pet.age .. " -- " .. AdoptMeConfigs.GetFirstSixLetters(pet.id)
		PlayerPetsTabel[index] = entry
		PlayersPets[index] = {id = pet.id, kind = pet.name, age = pet.age, countid = index}
	end
	FirstPetDropdown:Refresh(PlayerPetsTabel)
	SecondPetDropdown:Refresh(PlayerPetsTabel)
end

-- ==================== WAIT FUNCTIONS (cleaned & safe) ====================
function PetWait(Begin, Request, Pet1, Pet2)
	if Begin then
		local starttime = tick()
		repeat task.wait(0.5) until AdoptMeConfigs.GetPlayerInterior() == Request or (tick()-starttime) >= 10 or not AutoFarmFunctions.PetAutofarm.State
		return (tick()-starttime) >= 10
	else
		local starttime = tick()
		repeat
			task.wait(0.5)
			local Ailments = AdoptMeConfigs.GetAilments(Pet1, Pet2, false, DisabledAilments)
			local stillHasNeed = false
			if Ailments then
				if Pet1 then for k in pairs(Ailments.FirstPet or {}) do if k == Request then stillHasNeed = true break end end
				elseif Pet2 then for k in pairs(Ailments.SecondPet or {}) do if k == Request then stillHasNeed = true break end end end
			end
		until not stillHasNeed or (tick()-starttime) >= 60 or not AutoFarmFunctions.PetAutofarm.State
		return true
	end
end

function BabyWait(Begin, Request)
	if Begin then
		local starttime = tick()
		repeat task.wait(0.5) until AdoptMeConfigs.GetPlayerInterior() == Request or (tick()-starttime) >= 10 or not DoBabyAutoFarm
		return (tick()-starttime) >= 10
	else
		local starttime = tick()
		repeat
			task.wait(0.5)
			local Ailments = AdoptMeConfigs.GetAilments(nil, nil, true, DisabledAilments)
			local stillHasNeed = false
			if Ailments then
				for k in pairs(Ailments.Baby or {}) do if k == Request then stillHasNeed = true break end end
			end
		until not stillHasNeed or (tick()-starttime) >= 60 or not DoBabyAutoFarm
		return true
	end
end

