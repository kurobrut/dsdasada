-- ==================== PLATFORM ====================
function updatePlatformForLocalPlayer()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = LocalPlayer.Character.HumanoidRootPart
    if workspace:FindFirstChild("PlayerPlatform") then platform = workspace.PlayerPlatform end
    if not platform then
        platform = Instance.new("Part")
        platform.Size = platformSize
        platform.Color = platformColor
        platform.Anchored = true
        platform.CanCollide = true
        platform.Name = "PlayerPlatform"
        platform.Parent = workspace
    end
    local targetY = rootPart.Position.Y - (rootPart.Size.Y / 2 + platform.Size.Y / 2) - 2
    if math.abs(platform.Position.Y - targetY) > 10 then
        platform.Position = rootPart.Position - Vector3.new(0, (rootPart.Size.Y / 2 + platform.Size.Y / 2) + 2, 0)
    end
end

local function SetPlatformForPlayer(state)
    platformActive = state
    if platformActive then
        task.spawn(function()
            while platformActive do
                updatePlatformForLocalPlayer()
                task.wait(0.5)
            end
        end)
    end
end

-- ==================== PET HELPERS ====================
function UpdatePetDropdown()
    PlayersPets = {}
    PlayerPetsTabel = {}
    local sortablePets = {}
    for petid, petname in pairs(AdoptMeConfigs.GetPlayersInventory().pets) do
        if petname.id ~= "practice_dog" then
            table.insert(sortablePets, {id = petid, name = petname.id, age = petname.properties.age})
        end
    end
    table.sort(sortablePets, function(a,b)
        if a.name:lower() == b.name:lower() then return AdoptMeConfigs.NaturalSort(a.id, b.id) end
        return a.name:lower() < b.name:lower()
    end)
    for index, pet in ipairs(sortablePets) do
        local entry = index .. "=" .. pet.name .. ": " .. pet.age .. " -- " .. AdoptMeConfigs.GetFirstSixLetters(pet.id)
        PlayerPetsTabel[index] = entry
        PlayersPets[index] = {id = pet.id, kind = pet.name, age = pet.age, countid = index}
    end
    PetDropdown:Refresh(PlayerPetsTabel, true)
end

-- ==================== WAIT FUNCTIONS ====================
function PetWait(Begin, Request, PetId)
    if Begin then
        local start = tick()
        repeat task.wait(0.5) until AdoptMeConfigs.GetPlayerInterior() == Request or (tick() - start) >= 10 or not AutoFarmFunctions.PetAutofarm.State
        return (tick() - start) >= 10
    else
        local start = tick()
        repeat
            task.wait(0.5)
            local Ailments = AdoptMeConfigs.GetAilments(PetId, nil, false, {})
            local hasNeed = false
            if Ailments and Ailments.FirstPet then
                for k in pairs(Ailments.FirstPet) do if k == Request then hasNeed = true break end end
            end
        until not hasNeed or (tick() - start) >= 60 or not AutoFarmFunctions.PetAutofarm.State
        return true
    end
end

function BabyWait(Begin, Request)
    if Begin then
        local start = tick()
        repeat task.wait(0.5) until AdoptMeConfigs.GetPlayerInterior() == Request or (tick() - start) >= 10 or not DoBabyAutoFarm
        return (tick() - start) >= 10
    else
        local start = tick()
        repeat
            task.wait(0.5)
            local Ailments = AdoptMeConfigs.GetAilments(nil, nil, true, {})
            local hasNeed = false
            if Ailments and Ailments.Baby then
                for k in pairs(Ailments.Baby) do if k == Request then hasNeed = true break end end
            end
        until not hasNeed or (tick() - start) >= 60 or not DoBabyAutoFarm
        return true
    end
end

-- ==================== CIRCLE MOVEMENT ====================
local function startMoving(state)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
    if not root then return end
    
    if state then
        if isRunning then return end
        isRunning = true
        local center = root.Position
        
        local function getNextCirclePoint(c, a)
            return c + Vector3.new(math.cos(a) * radius, 0, math.sin(a) * radius)
        end
        
        runService:BindToRenderStep("CircleMovement", Enum.RenderPriority.Character.Value, function(deltaTime)
            if not isRunning or not root.Parent then return end
            angle = angle + speed * deltaTime
            humanoid:MoveTo(getNextCirclePoint(center, angle))
        end)
    else
        isRunning = false
        runService:UnbindFromRenderStep("CircleMovement")
        humanoid:MoveTo(root.Position)
        task.spawn(function() task.wait(0.1) if humanoid then humanoid.Jump = true end end)
    end
end

