-- ==================== MAIN FARM (FULL ERROR PROTECTION) ====================
local PetFarmFunction = function()
    SetPlatformForPlayer(true)
    if not AutoFarmFunctions.PetAutofarm.State then
        SetPlatformForPlayer(false)
        AutoFarmFunctions.PetAutofarm.Running = false
        return
    end

    if FirstSelectedPet ~= "None" then
        local ailments = AdoptMeConfigs.GetAilments(FirstSelectedPet, nil, false, DisabledAilments)
        if ailments and ailments.FirstPet then
            for needType in pairs(ailments.FirstPet) do
                if DoPetNeed[needType] and EnabledNeeds[needType] then
                    local success, err = pcall(function()
                        AdoptMeConfigs.PrintDebugMessages("Doing: " .. needType .. " (FirstPet)", DebugMessages)
                        DoPetNeed[needType](FirstSelectedPet, nil)
                    end)
                    if not success then Notification("First Pet " .. needType .. " error: " .. tostring(err)) end
                end
            end
        end
    end

    if SecondSelectedPet ~= "None" then
        local ailments = AdoptMeConfigs.GetAilments(nil, SecondSelectedPet, false, DisabledAilments)
        if ailments and ailments.SecondPet then
            for needType in pairs(ailments.SecondPet) do
                if DoPetNeed[needType] and EnabledNeeds[needType] then
                    local success, err = pcall(function()
                        DoPetNeed[needType](nil, SecondSelectedPet)
                    end)
                    if not success then Notification("Second Pet " .. needType .. " error: " .. tostring(err)) end
                end
            end
        end
    end

    if DoBabyAutoFarm then
        local ailments = AdoptMeConfigs.GetAilments(nil, nil, true, DisabledAilments)
        if ailments and ailments.Baby then
            for needType in pairs(ailments.Baby) do
                if DoBabyNeed[needType] and EnabledNeeds[needType] then
                    local success, err = pcall(DoBabyNeed[needType])
                    if not success then Notification("Baby " .. needType .. " error: " .. tostring(err)) end
                end
            end
        end
    end

    AutoFarmFunctions.PetAutofarm.Running = false
    task.wait(2)
end

