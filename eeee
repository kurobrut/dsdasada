	-- ==================== FIXED MYSTERY (no unequip spam, silent, stable) ====================
	["mystery"] = function(PetId)
		-- NO UpdatePlayerPets() here → stops re-equipping forever
		local petConfig = AdoptMeConfigs.GetPlayersPetConfigs(PetId)
		if not petConfig then
			return
		end

		local PetArg = {
			is_pet = true,
			pet_unique = PetId,
			player = LocalPlayer,
			pet_id = petConfig.petKind,
		}

		local chosen = "play" -- safest default in 2026

		pcall(function()
			local oldiden = getiden()
			setiden(2)

			local ailmentsData = AilmentsClientRe.get_ailments_for_pet(PetArg)
			if
				ailmentsData
				and ailmentsData.mystery
				and ailmentsData.mystery.action
				and ailmentsData.mystery.action.options
			then
				if typeof(ailmentsData.mystery.action.options.get_ailment_slots) == "function" then
					local options = ailmentsData.mystery.action.options.get_ailment_slots(
						ailmentsData.mystery.action.options.random_seed or 0,
						ailmentsData,
						PetArg
					)
					if options and type(options) == "table" and options[1] then
						chosen = options[1]
					end
				end
			end
			setiden(oldiden)
		end)

		pcall(function()
			AdoptMeConfigs.RunRouterClient(true, "AilmentsAPI/ChooseMysteryAilment", {
				[1] = PetId,
				[2] = "mystery",
				[3] = 1,
				[4] = chosen,
			})
			task.wait(1.4 + math.random(4, 11) / 10) -- human-like delay
		end)
	end,

	["pet_me"] = function(PetId) -- (same)
		UpdatePlayerPets()
		local currentPet = AdoptMeConfigs.GetCurrentPet(PetId)
		if not currentPet then
			return
		end

		for i = 1, 5 do
			task.wait(1)
			if not AdoptMeConfigs.GetCurrentPet(PetId) then
				return
			end

			local petModel = currentPet.base.pet_model.Parent
			AdoptMeConfigs.RunRouterClient(true, "AdoptAPI/FocusPet", { [1] = petModel })
			AdoptMeConfigs.RunRouterClient(
				true,
				"PetAPI/ReplicateActivePerformances",
				{ [1] = petModel, [2] = { FocusPet = true } }
			)
			AdoptMeConfigs.RunRouterClient(true, "AilmentsAPI/ProgressPetMeAilment", { [1] = PetId })
		end

		PetWait(false, "pet_me", PetId)
	end,
}

